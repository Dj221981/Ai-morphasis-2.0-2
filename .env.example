# Ai-morphasis Environment Configuration
# Copy this file to .env and customize as needed

# Application
DEBUG=false
LOG_LEVEL=INFO

# Agent Configuration
MAX_AGENTS=100
AGENT_MEMORY_SIZE=10000

# Game Configuration
GAME_WIDTH=1280
GAME_HEIGHT=720
TARGET_FPS=60

# Model Configuration
MODEL_DEVICE=cpu
BATCH_SIZE=32
LEARNING_RATE=0.001

# Logging
LOG_FILE=logs/ai_morphasis.log

# Persistence Backend
# Use a SQLite URL for local/dev, PostgreSQL for production
PERSISTENCE_BACKEND=sqlite          # sqlite | postgres | redis
DATABASE_URL=sqlite:///data/tasks.db
# DATABASE_URL=******localhost:5432/ai_morphasis

# Redis (used when PERSISTENCE_BACKEND=redis)
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=agent:task:
REDIS_TTL_SECONDS=604800            # 7 days; set to 0 to disable TTL
