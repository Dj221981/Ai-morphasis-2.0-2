# Ai-morphasis Environment Configuration
# Copy this file to .env and customize as needed

# Application
APP_ENV=development          # Required: set to development, staging, or production
DEBUG=false
LOG_LEVEL=INFO

# API / network
# Comma-separated list of allowed CORS origins.
# Use "*" in development only; set explicit origins in staging/production.
CORS_ORIGINS=*
# Rate limit applied to non-probe endpoints per client IP.
RATE_LIMIT=60/minute

# Agent Configuration
MAX_AGENTS=100
AGENT_MEMORY_SIZE=10000

# Game Configuration
GAME_WIDTH=1280
GAME_HEIGHT=720
TARGET_FPS=60

# Model Configuration
MODEL_DEVICE=cpu
BATCH_SIZE=32
LEARNING_RATE=0.001

# Logging
LOG_FILE=logs/ai_morphasis.log
