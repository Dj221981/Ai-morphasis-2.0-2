# Ai-morphasis-2.0-2 Environment Configuration
# Copy this file to .env and fill in the values before starting the service.

# ── Required ──────────────────────────────────────────────────────────────────

# Deployment environment. Must be: development | staging | production
APP_ENV=development

# ── Authentication ─────────────────────────────────────────────────────────────

# API key for X-API-Key header authentication on protected endpoints.
# Leave empty to disable authentication (development only).
# Example: openssl rand -hex 32
API_KEY=

# ── Application ────────────────────────────────────────────────────────────────

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to true to enable FastAPI debug mode (development only)
DEBUG=false

# ── Rate limiting ──────────────────────────────────────────────────────────────

# slowapi rate limit applied to protected endpoints (e.g. "60/minute", "1000/hour")
RATE_LIMIT=60/minute

# ── Model Configuration ────────────────────────────────────────────────────────

# Device for model inference: cpu | cuda
MODEL_DEVICE=cpu
BATCH_SIZE=32
LEARNING_RATE=0.001

# ── Logging (optional file output) ────────────────────────────────────────────

# Leave empty to log to stdout only (recommended for containers)
LOG_FILE=
